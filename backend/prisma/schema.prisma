generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
}

model Patient {
  id                   String          @id @default(cuid())
  fullName             String
  dateOfBirth          DateTime
  age                  Int
  educationalFramework String?
  frameworkType        String?
  treatmentFramework   String
  mainConcerns         String?
  treatmentGoals       String?
  status               String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  patientContacts      PatientContact[]
  sessions             Session[]
  documents            Document[]
  images               Image[]
}

model Contact {
  id                String          @id @default(cuid())
  fullName          String
  role              String
  phone             String?
  email             String?
  address           String?
  preferredLanguage String?
  generalNotes      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  patientContacts   PatientContact[]
  documents         Document[]
}

model PatientContact {
  id                    String   @id @default(cuid())
  patientId             String
  contactId             String
  relationshipToPatient String?
  involvementStatus     String?
  sharingConsent        Boolean  @default(false)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  patient               Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  contact               Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([patientId, contactId])
}

model LegacyStakeholder {
  id                String   @id
  patientId         String
  fullName          String
  role              String
  phone             String?
  email             String?
  address           String?
  notes             String?
  preferredLanguage String?
  involvementStatus String?
  sharingConsent    Boolean
  createdAt         DateTime
  updatedAt         DateTime

  @@map("Stakeholder")
}

model Session {
  id                 String   @id @default(cuid())
  patientId          String
  date               DateTime
  startTime          String
  durationMinutes    Int
  sessionType        String
  frameworkType      String?
  location           String?
  attendees          String?
  goal               String?
  sessionDescription String?
  materialsUsed      String?
  behaviorNotes      String?
  clinicalImpression String?
  followUpNotes      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  patient            Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  images             Image[]
}

model Document {
  id           String   @id @default(cuid())
  patientId    String
  contactId    String?  @map("stakeholderId")
  title        String
  documentType String
  sourceType   String?
  authorName   String?
  tags         String?
  filePath     String
  uploadedAt   DateTime @default(now())
  notes        String?
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Image {
  id          String    @id @default(cuid())
  patientId   String
  sessionId   String?
  title       String
  description String?
  imageType   String
  filePath    String
  capturedAt  DateTime?
  notes       String?
  uploadedAt  DateTime  @default(now())
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
}
